# Copy to ml/.env for local dev. OpenAI-shape endpoint — dev uses Ollama,
# prod uses vLLM. Swapping engines is just these values.

LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=huihui_ai/qwen3.5-abliterated:4b-Claude
LLM_API_KEY=ollama
LLM_MAX_MODEL_LEN=32768
LLM_STREAM_USAGE=false
PORT=8090

# Embeddings (OpenAI-shape). Dev: Ollama bge-m3 (1024-dim). Prod: Qwen3-Embedding.
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_MODEL=hf.co/ggml-org/bge-m3-Q8_0-GGUF:Q8_0
EMBED_API_KEY=ollama

# Reranker via /v1/rerank. Dev: llama.cpp server (Qwen3-Reranker GGUF, --reranking).
# Prod: Qwen3-Reranker service. base_url has NO /v1 suffix.
RERANK_ENABLED=true
RERANK_BASE_URL=http://localhost:8091
RERANK_MODEL=Qwen3-Reranker-0.6B

QDRANT_URL=http://localhost:6333

# Groundedness verifier (Mode A — live RAG-answer faithfulness). Off by default.
# Dev: the reference LettuceDetect sidecar in backend/deploy/verify (port 8095).
# base_url has NO /v1 suffix. Also needs features.groundedness=true on the backend.
VERIFY_ENABLED=false
VERIFY_BASE_URL=http://localhost:8095
VERIFY_MODEL=KRLabsOrg/lettucedect-large-modernbert-en-v1

# Agentic retrieval knobs
TOP_K=8
OVER_RETRIEVAL=4
# Dev default is low for the slow local LLM; prod tunes toward the 5–6 cap.
MAX_ROUNDS=2
CHUNK_SIZE=1500
CHUNK_OVERLAP=400

# Prod (vLLM) example:
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen3-...
# LLM_STREAM_USAGE=true
