# PAI ML/RAG service env — PROFILE A: Linux + vLLM + NVIDIA/ROCm.
# Copy to /etc/pai/ml.env (EnvironmentFile in systemd/pai-ml.service).
# The ML service is the LLM client; everything is OpenAI-shape HTTP, so the
# inference engine is swappable by URL/model — nothing here is vLLM-specific.

# Main LLM — vLLM OpenAI-compatible endpoint.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=Qwen/Qwen3-…             # the deployment's served model
LLM_API_KEY=                       # vLLM may require a key
LLM_MAX_MODEL_LEN=65536            # fallback; vLLM also advertises via /v1/models
LLM_STREAM_USAGE=true              # vLLM supports stream_options.include_usage
LLM_GUIDED_DECODING=true           # vLLM xgrammar: constrain decompose/grade/plan/etc. (off elsewhere)

# Embeddings (Qwen3-Embedding service) + reranker (Infinity/llama.cpp).
EMBED_BASE_URL=http://127.0.0.1:8001/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-…
RERANK_ENABLED=true
RERANK_BASE_URL=http://127.0.0.1:8091
RERANK_MODEL=Qwen3-Reranker-0.6B

QDRANT_URL=http://127.0.0.1:6333

# Groundedness verifier (Mode A — live faithfulness). External cross-encoder on
# GPU2 or CPU; base_url has NO /v1 suffix. Off unless the deployment wants it.
# Needs features.groundedness=true on the backend. See deploy/verify/README.md.
VERIFY_ENABLED=false
VERIFY_BASE_URL=http://127.0.0.1:8095
VERIFY_MODEL=KRLabsOrg/lettucedect-large-modernbert-en-v1

# Retrieval / agentic loop — tune to GPU headroom.
MAX_ROUNDS=3
TOP_K=8
TABULAR_CONCURRENCY=8

# LibreOffice on PATH for the Linux box.
SOFFICE_BIN=soffice

# Voice (OpenAI-audio contract) — off unless the deployment wants it. Separate
# STT/TTS servers. See deploy/voice/README.md.
STT_ENABLED=false
STT_BASE_URL=http://127.0.0.1:8092
STT_MODEL=qwen3-asr
TTS_ENABLED=false
TTS_BASE_URL=http://127.0.0.1:8093
TTS_MODEL=omnivoice
TTS_VOICE=default
TTS_FORMAT=wav

# --- Air-gap offline guard (ts-enterprise-airgap D5) ---------------------------
# The only runtime model download is the fastembed `Qdrant/bm25` sparse model.
# Forcing HF offline mode makes a stray pull fail loudly instead of silently
# reaching the network; pre-provision the fastembed cache in the offline bundle.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
