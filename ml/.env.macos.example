# PAI ML/RAG service env — PROFILE B: macOS Mac Studio + llama.cpp.
# Copy to /etc/pai/ml.macos.env. Same code as Linux; only these values differ.
#
# IMPORTANT: run llama.cpp's server (llama-server) with a tool-capable chat
# template so its OpenAI endpoint emits structured `tool_calls` (e.g. `--jinja`
# with a template that supports tools). Otherwise tool calls silently no-op —
# this is llama.cpp deployment config, not platform code.

# Main LLM — llama-server OpenAI-compatible endpoint (unified memory).
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=qwen3                    # whatever llama-server reports
LLM_API_KEY=none
LLM_MAX_MODEL_LEN=32768            # llama.cpp often omits this from /v1/models → fallback used
LLM_STREAM_USAGE=false             # safest across servers

# Embeddings + reranker via llama.cpp servers (or Ollama) — OpenAI-shape.
EMBED_BASE_URL=http://127.0.0.1:8081/v1
EMBED_MODEL=bge-m3
RERANK_ENABLED=true
RERANK_BASE_URL=http://127.0.0.1:8091
RERANK_MODEL=Qwen3-Reranker-0.6B

QDRANT_URL=http://127.0.0.1:6333

# Groundedness verifier (Mode A — live faithfulness). LettuceDetect on CPU is
# fine; base_url has NO /v1 suffix. Off unless wanted. Needs
# features.groundedness=true on the backend. See deploy/verify/README.md.
VERIFY_ENABLED=false
VERIFY_BASE_URL=http://127.0.0.1:8095
VERIFY_MODEL=KRLabsOrg/lettucedect-large-modernbert-en-v1

# Smaller unified-memory budget → keep the agentic loop lean.
MAX_ROUNDS=2
TOP_K=6
TABULAR_CONCURRENCY=2

# macOS LibreOffice bundle path (render.py also probes this automatically).
SOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Voice (OpenAI-audio contract). Separate llama-server instances/ports.
# STT: Qwen3-ASR GGUF; TTS: OmniVoice GGUF. See deploy/voice/README.md.
STT_ENABLED=true
STT_BASE_URL=http://127.0.0.1:8092
STT_MODEL=qwen3-asr
# Raw llama.cpp Qwen3-ASR has no /v1/audio/transcriptions — it takes audio via
# /v1/chat/completions (input_audio). Use the chat adapter. A wrapper that exposes
# the OpenAI endpoint can use STT_FORMAT=openai instead.
STT_FORMAT=chat
TTS_ENABLED=true
TTS_BASE_URL=http://127.0.0.1:8093
TTS_MODEL=omnivoice
TTS_VOICE=default
TTS_FORMAT=wav
