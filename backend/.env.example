# Copy to `.env` for local development (the dev datastores live in
# deploy/docker-compose.dev.yml; Postgres is on host port 5433 to avoid a
# clash with a native install on 5432).
#
# Boot config uses the `PAI__` prefix with `__` to nest (figment).

PAI__DATABASE_URL=postgres://pai:pai@localhost:5433/pai
PAI__REDIS_URL=redis://localhost:6379
PAI__SERVER__HOST=0.0.0.0
PAI__SERVER__PORT=8080
PAI__SERVER__STATIC_DIR=../frontend/dist
PAI__LOG_LEVEL=info

# Keycloak. Config nests as url + realm (the issuer is derived: {url}/realms/{realm});
# is_configured() needs url + realm — without them the whole /api/* subtree is dropped.
PAI__KEYCLOAK__URL=http://localhost:8081
PAI__KEYCLOAK__REALM=fosnie
PAI__KEYCLOAK__CLIENT_ID=fosnie
PAI__KEYCLOAK__CLIENT_SECRET=

# Python ML service (the platform's LLM client + RAG). WebSocket clients connect
# to /ws with `?token=<jwt>` (browsers cannot set the Authorization header) or
# reconnect with `?resume=<token>`. Uploaded RAG documents land under documents_dir.
PAI__ML__BASE_URL=http://localhost:8090
PAI__STORAGE__DOCUMENTS_DIR=./data/documents

# sqlx-cli and compile-time query checks (`cargo build`, `sqlx migrate`,
# `cargo sqlx prepare`) read DATABASE_URL directly:
DATABASE_URL=postgres://pai:pai@localhost:5433/pai
