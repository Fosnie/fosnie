  "db_name": "PostgreSQL",
  "query": "\n        SELECT id,\n               task_type::text AS \"task_type!\",\n               payload,\n               retry_count,\n               max_retries\n        FROM tasks\n        WHERE status = 'queued' AND next_attempt_at <= now()\n        ORDER BY priority, next_attempt_at\n        LIMIT $1\n        FOR UPDATE SKIP LOCKED\n        ",
