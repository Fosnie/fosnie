  "query": "SELECT base_url, model, api_key_encrypted, enabled, reasoning_mode\n               FROM provider_configs\n               WHERE role = $1\n                 AND ( (scope = 'user' AND scope_id = $2)\n                    OR (scope = 'deployment' AND scope_id IS NULL) )\n               ORDER BY (scope = 'user') DESC\n               LIMIT 1",
