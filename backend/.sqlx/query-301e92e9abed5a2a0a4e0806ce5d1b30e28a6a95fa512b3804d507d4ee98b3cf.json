{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT EXISTS (\n            SELECT 1 FROM access_grants g\n            WHERE g.resource_type = $1\n              AND g.resource_id = $2\n              AND g.permission = $3\n              AND (\n                    (g.principal_type = 'user'  AND g.principal_id = $4)\n                 OR (g.principal_type = 'group' AND g.principal_id IN\n                        (SELECT group_id FROM group_members WHERE user_id = $4))\n              )\n        ) AS \"allowed!\"\n        ",
  "describe": {
    "columns": [
      {
        "ordinal": 0,
        "name": "allowed!",
        "type_info": "Bool",
        "origin": "Expression"
      }
    ],
