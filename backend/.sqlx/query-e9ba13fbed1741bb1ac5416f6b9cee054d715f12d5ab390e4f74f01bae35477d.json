  "query": "SELECT w.message_id, w.url, w.title, w.domain, w.published_date, w.fetched_at, w.quote_text, w.snippet_only\n           FROM web_citations w JOIN messages m ON m.id = w.message_id\n           WHERE m.chat_id = $1 ORDER BY w.created_at, w.id",
