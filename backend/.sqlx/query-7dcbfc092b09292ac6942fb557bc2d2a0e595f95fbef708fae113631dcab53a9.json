  "query": "SELECT id, name, owner_user_id, next_run_at AS \"next_run_at!\"\n           FROM automations\n           WHERE status = 'active'\n             AND next_run_at IS NOT NULL\n             AND next_run_at > now()\n             AND next_run_at <= now() + ($1::int * interval '1 second')\n             AND (reminded_for IS NULL OR reminded_for <> next_run_at)",
