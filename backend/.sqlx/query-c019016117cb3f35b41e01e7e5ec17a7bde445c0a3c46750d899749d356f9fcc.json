  "query": "SELECT w.id, w.device_id, d.name AS device_name, w.path, w.label, w.tier, w.trusted_at, w.last_used_at, w.revoked_at FROM device_workspaces w JOIN devices d ON d.id = w.device_id WHERE w.user_id = $1 ORDER BY w.trusted_at DESC",
