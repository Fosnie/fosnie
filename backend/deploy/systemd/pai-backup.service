# One-shot PAI backup, driven by pai-backup.timer. Config lives in
# /etc/pai/backup.env (PAI_DB_URL, PAI_QDRANT_URL, PAI_STORAGE_DIRS,
# PAI_BACKUP_DIR, PAI_BACKUP_RETAIN, optional PAI_BACKUP_AGE_RECIPIENT).
[Unit]
Description=PAI Platform backup (Postgres + Qdrant + storage)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=pai
Group=pai
EnvironmentFile=/etc/pai/backup.env
ExecStart=/opt/pai/deploy/scripts/backup.sh
# Backups are I/O heavy but not urgent — keep them off the platform's back.
Nice=10
IOSchedulingClass=idle
# Hardening: the job only needs to read the stores and write the backup dir.
ProtectSystem=strict
ReadWritePaths=/var/backups/pai
PrivateTmp=true
NoNewPrivileges=true
