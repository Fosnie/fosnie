# Fosnie — deployment .env (minimal). The installer regenerates every secret
# below; NEVER ship these placeholder values to production.
#
# Everything else (providers, features, integrations) is configured at runtime in
# the admin UI, or defaulted inside the images. Service hostnames live in
# docker-compose.yml, not here.

# ── Version + port ────────────────────────────────────────────────────────────
# Pin a released version for reproducible upgrades (semver-compatible within a
# minor). `latest` tracks the newest release.
APP_VERSION=latest
# Host port the browser reaches Fosnie on → http://localhost:8080
HOST_PORT=8080

# ── Secrets (installer regenerates — do not reuse these) ──────────────────────
# Postgres password (any string):            openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE-ME-postgres-password
# At-rest encryption key — base64 of 32 bytes: openssl rand -base64 32
# (A set-but-invalid key fails the boot on purpose; leave it valid.)
MESSAGE_ENCRYPTION_KEY=CHANGE-ME-base64-32-bytes
# Backend↔ML shared secret (any string):     openssl rand -hex 32
ML_SHARED_SECRET=CHANGE-ME-ml-shared-secret
# Optional: Ed25519 audit-signing seed — 32-byte hex: openssl rand -hex 32
# Leave empty for hash-chain-only audit (tamper-detection).
AUDIT_SIGNING_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# local (default) = built-in email/password; keycloak = OIDC (needs PAI__KEYCLOAK__*).
AUTH_MODE=local
# Set only if you serve Fosnie on a domain (must be https for a non-loopback host;
# put a TLS reverse proxy in front — see the README). Defaults to localhost.
# PUBLIC_URL=https://fosnie.example.org
# Set by `install.sh --local` — seeds Ollama/reranker providers on boot. Leave
# empty for external-inference mode (bring your own key in the admin UI).
LOCAL_STACK=

# ── Managed Postgres (Supabase/Neon/RDS/Cloud SQL/Azure) ──────────────────────
# To use an external database instead of the bundled `postgres` service:
#   1. remove/stop the `postgres` service in docker-compose.yml, and
#   2. set the full DSN here (session-mode/direct pooler, never transaction-mode):
# PAI__DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
