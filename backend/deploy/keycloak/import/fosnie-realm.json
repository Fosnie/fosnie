{
  "realm": "fosnie",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Client IT Lead (persistent client-admin)"
      },
      {
        "name": "power_user",
        "description": "Sets up Projects, Project Knowledge, groups"
      },
      {
        "name": "user",
        "description": "Ordinary user"
      }
    ],
    "client": {
      "fosnie": [
        {
          "name": "scim-provision",
          "description": "Permits a service-account JWT to call the SCIM 2.0 provisioning API (D4 alternative to a static token)."
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "fosnie",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "fosnie-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8088/*",
        "http://localhost:8080/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8088/*##http://localhost:8080/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "fosnie-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fosnie",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "fosnie-spa",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8080/*",
        "https://chat.example.com/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8080",
        "https://chat.example.com"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost:8080/*##https://chat.example.com/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "fosnie-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fosnie",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "brokered-groups-to-groups-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "groups",
            "claim.name": "groups",
            "jsonType.label": "String",
            "multivalued": "true",
            "aggregate.attrs": "true",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-fosnie",
      "enabled": true,
      "serviceAccountClientId": "fosnie",
      "clientRoles": {
        "realm-management": [
          "manage-identity-providers",
          "view-realm"
        ],
        "fosnie": [
          "scim-provision"
        ]
      }
    },
    {
      "id": "0a1ce000-0000-4000-8000-000000000001",
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Admin",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "default-roles-fosnie"
      ]
    },
    {
      "id": "0b0b0000-0000-4000-8000-000000000002",
      "username": "bob",
      "enabled": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Power",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "realmRoles": [
        "power_user",
        "default-roles-fosnie"
      ]
    },
    {
      "id": "ca701000-0000-4000-8000-000000000003",
      "username": "carol",
      "enabled": true,
      "email": "carol@example.com",
      "firstName": "Carol",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "carol",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "default-roles-fosnie"
      ]
    }
  ]
}
