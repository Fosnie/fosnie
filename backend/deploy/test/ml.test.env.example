# PAI ML/RAG service — TEST env (container, host networking).
# Loaded by docker-compose (env_file). Field names = Settings fields, upper-cased
# (ml/app/config.py, pydantic BaseSettings). SHARED_SECRET is injected from the
# compose .env (ML_SHARED_SECRET) so it stays out of git.
#
# On a fresh server: cp ml.test.env.example ml.test.env
# No secrets in this file — SHARED_SECRET comes from .env, not here.

# ── Main LLM (vLLM, GPU0) ───────────────────────────────────────────────────
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=qwen3                       # must match vllm-main --served-model-name
LLM_API_KEY=dummy                     # vLLM doesn't require a real key; must be non-empty
LLM_MAX_MODEL_LEN=65536               # fallback; vLLM also advertises via /v1/models
LLM_DEFAULT_MAX_TOKENS=8192           # think+answer budget for the reasoning model; <4k risks empty answers
LLM_STREAM_USAGE=true
LLM_GUIDED_DECODING=true              # vLLM xgrammar — constrain decompose/grade/plan

# ── OCR (GLM-OCR via vLLM, GPU1) ────────────────────────────────────────────
OCR_BASE_URL=http://127.0.0.1:8002/v1
OCR_MODEL=glm-ocr                     # must match vllm-ocr --served-model-name

# ── Embeddings (Qwen3-Embedding-4B via vLLM, GPU1) ──────────────────────────
EMBED_BASE_URL=http://127.0.0.1:8001/v1
EMBED_MODEL=qwen3-embedding           # must match vllm-embed --served-model-name

# ── Reranker (Qwen3-Reranker-0.6B via llama.cpp, GPU1) ──────────────────────
RERANK_ENABLED=true
RERANK_BASE_URL=http://127.0.0.1:8091    # code appends /v1/rerank
RERANK_MODEL=Qwen3-Reranker-0.6B

# ── Datastores ──────────────────────────────────────────────────────────────
QDRANT_URL=http://127.0.0.1:6333

# ── Path confinement (defence-in-depth) ─────────────────────────────────────
STORAGE_ROOT=/var/lib/pai

# ── Retrieval / agentic loop — tune to GPU headroom ─────────────────────────
MAX_ROUNDS=3
TOP_K=8
TABULAR_CONCURRENCY=8

# ── Document toolchain (installed in the image) ─────────────────────────────
SOFFICE_BIN=soffice
PANDOC_BIN=pandoc

# ── Voice: STT (Qwen3-ASR via llama.cpp) ────────────────────────────────────
# Qwen3-ASR takes audio on /v1/chat/completions → STT_FORMAT=chat (deploy/voice).
STT_ENABLED=true
STT_BASE_URL=http://127.0.0.1:8092
STT_MODEL=qwen3-asr
STT_FORMAT=chat

# ── Voice: TTS (kokoro-fastapi, OpenAI /v1/audio/speech) ────────────────────
TTS_ENABLED=true
TTS_BASE_URL=http://127.0.0.1:8880
TTS_MODEL=kokoro
TTS_VOICE=af_sky
TTS_FORMAT=wav

# ── Groundedness verifier (LettuceDetect sidecar) ───────────────────────────
VERIFY_ENABLED=true
VERIFY_BASE_URL=http://127.0.0.1:8095
VERIFY_MODEL=KRLabsOrg/lettucedect-large-modernbert-en-v1

# ── Web search (SearXNG). The service is up; the connector is still gated by
#    the runtime switch in Admin → Integrations → web_search (flip it on there).
WEB_SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://127.0.0.1:8888
WEB_RENDER_ENABLED=true
