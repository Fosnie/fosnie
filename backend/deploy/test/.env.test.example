# Copy to `.env` and fill in. Consumed by `docker compose --env-file .env ...`.
# Keep the real .env out of git (already covered by the repo .gitignore for env files).

# ── Hugging Face (model downloads) ──────────────────────────────────────────
# Needed if any model repo is gated/needs auth. Get one at
# https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Platform secrets ────────────────────────────────────────────────────────
# Shared secret between the Rust backend and the ML service (X-PAI-ML-Key).
# Generate: openssl rand -hex 32
ML_SHARED_SECRET=CHANGE-ME-openssl-rand-hex-32

# Keycloak confidential-client secret. The dev realm seed ships this value;
# leave as-is unless you rotate it in the realm.
KEYCLOAK_CLIENT_SECRET=fosnie-secret
KC_ADMIN_PASSWORD=admin

# Optional but recommended (else DMs are plaintext / audit log unsigned).
# Generate each: openssl rand -hex 32
MESSAGE_ENCRYPTION_KEY=
AUDIT_SIGNING_KEY=

# ── Model selection (override the compose defaults if you want) ─────────────
# Main LLM, tensor-parallel over BOTH A100s. A100 = Ampere = no FP8 compute →
# int4 (AWQ/GPTQ), not FP8. At gpu-util 0.75 the GPU1 support models still fit.
LLM_MODEL=alexxorm/Huihui-Qwen3.6-27B-abliterated-AWQ
LLM_SERVED_NAME=qwen3
LLM_MAX_MODEL_LEN=65536
EMBED_MODEL=Qwen/Qwen3-Embedding-4B

# Pin the vLLM image tag for reproducibility (don't ride :latest in a real test).
# Find tags at https://hub.docker.com/r/vllm/vllm-openai/tags
VLLM_TAG=latest

# ── Public access (only for docker-compose.public.yml) ──────────────────────
# Cloudflare Tunnel token — exposes the demo at https://chat.example.com
# with no open ports. See PUBLIC-ACCESS.md. Leave blank for a localhost-only run.
CLOUDFLARE_TUNNEL_TOKEN=
